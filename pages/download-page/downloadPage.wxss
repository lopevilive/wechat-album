/* pages/download-handler/download-handler.wxss */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center; /* 确保所有元素在屏幕垂直水平双居中 */
  background-color: #ffffff;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.success-box, .loading-box, .error-box {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin: 60rpx 0 80rpx; /* 加大标题与按钮之间的距离 */
  color: #333333;
}

/* 按钮样式优化 */
.main-btn {
  width: 90% !important; /* 增加宽度 */
  background-color: #07c160 !important;
  color: #ffffff !important;
  font-size: 34rpx; /* 稍微减小字号确保不换行 */
  font-weight: 500;
  height: 100rpx;
  line-height: 100rpx;
  padding: 0;
  border-radius: 12rpx;
  margin-bottom: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 按下态反馈 */
.main-btn:active {
  background-color: #06ad56 !important;
}

/* 返回链接 */
.back-link {
  font-size: 30rpx;
  color: #576b95;
  padding: 20rpx;
}

/* 错误状态按钮颜色 */
.retry-btn {
  background-color: #f2f2f2 !important;
  color: #333333 !important;
}

/* 加载动画样式保持不变 */
.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}