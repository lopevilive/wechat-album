/* ==========================================================================
   1. 全局基础样式与页面适配
   ========================================================================== */
page {
  background-color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #334155;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==========================================================================
   2. 头部店铺精美卡片
   ========================================================================== */
.header-card {
  margin: 30rpx;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.15);
}

.shop-box {
  display: flex;
  align-items: center;
}

.header-card .img-shop {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  margin-right: 24rpx;
  background-color: #f1f5f9;
}

.header-card .shop-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.header-card .vip-status-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}

.header-card .vip-status-tag.is-vip {
  color: #fbbf24;
  font-weight: 500;
}

/* ==========================================================================
   3. 区域公用标题
   ========================================================================== */
.section-title {
  margin: 40rpx 30rpx 20rpx 30rpx;
  display: flex;
  flex-direction: column;
}

.section-title .title-txt {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  position: relative;
}

/* ==========================================================================
   4. 垂直平铺套餐大卡片
   ========================================================================== */
.combo-vertical-list {
  padding: 0 30rpx;
}

.combo-v-item {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border: 3rpx solid #e2e8f0;
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s ease-in-out;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.01);
}

/* 选中高亮状态：温暖轻奢金沙色调 */
.combo-v-item.active-item {
  border-color: #d97706;
  background: linear-gradient(180deg, #fef3c7 0%, #fffbeb 25%, #ffffff 100%);
  box-shadow: 0 12rpx 24rpx rgba(217, 119, 6, 0.08);
}

.combo-v-item.active-item .v-name {
  color: #78350f;
  font-weight: 700;
}

.combo-v-item.active-item .v-level-tag {
  background: #d97706;
  color: #ffffff;
}

.combo-v-item.active-item .price-content {
  color: #b45309;
}

.combo-v-item.active-item .card-line {
  background: rgba(217, 119, 6, 0.15);
}

/* 过滤掉的历史低版本置灰 */
.combo-v-item.disabled-item {
  background: #f8fafc;
  border-color: #f1f5f9;
  opacity: 0.5;
}

/* 卡片头部样式 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.v-left {
  display: flex;
  flex-direction: column;
}

.v-name {
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.v-level-tag {
  font-size: 20rpx;
  background: #e2e8f0;
  color: #64748b;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-right: 14rpx;
  font-weight: 700;
}

.v-right {
  text-align: right;
}

.combo-v-item .price-content {
  display: flex;
  align-items: baseline;
  color: #1e293b;
}

.combo-v-item .price-content .unit {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 4rpx;
}

.combo-v-item .price-content .num {
  font-size: 52rpx;
  font-weight: 700;
}

.combo-v-item .time-unit {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 6rpx;
  font-weight: normal;
}

/* 卡片中间默认折线 */
.card-line {
  height: 2rpx;
  background: #f1f5f9;
  margin: 24rpx 0 20rpx 0;
  width: 100%;
}

/* ==========================================================================
   ✨ 核心重构：纯平铺、无外框、绝对一根线对齐的核心产品容量行
   ========================================================================== */
.main-capacity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 10rpx 4rpx; /* 彻底卸掉厚重的卡片外框，完全和下方的文字平齐 */
  box-sizing: border-box;
}

.main-capacity-row .cap-left {
  display: flex;
  align-items: center;
}

/* 适当放大核心容量的图标，强化其排头兵的视觉分量 */
.main-capacity-row .inner-icon-big {
  width: 40rpx;
  height: 40rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.main-capacity-row .cap-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.main-capacity-row .cap-right {
  display: flex;
  align-items: baseline;
}

/* 核心大数字：在无框的极简状态下，依旧对标视频特大号 */
.main-capacity-row .cap-num {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  margin-right: 6rpx;
}

.main-capacity-row .cap-unit {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

/* 核心容量与下方普通图文之间的辅助细线 */
.card-line-thin {
  height: 1rpx;
  background: #f1f5f9;
  margin: 16rpx 0 24rpx 0;
  width: 100%;
}
.active-item .card-line-thin {
  background: rgba(217, 119, 6, 0.12);
}

/* ---------- 核心数字/单位的高亮色系 ---------- */
.main-capacity-row .vip-orange-text {
  color: #d97706 !important;
}
.main-capacity-row .vip-gradient-text {
  background: linear-gradient(135deg, #bf9546 0%, #8c6216 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: inline-block;
}
.main-capacity-row .vip-unit {
  color: #8c6216;
  font-weight: 600;
}
.main-capacity-row .vip-spark-tag {
  display: inline-block;
  font-size: 16rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 10rpx;
  align-self: center;
}

/* ==========================================================================
   5. 内嵌基础权益平铺列表（支持双列混合单全列）
   ========================================================================== */
.card-rights-inner {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  padding-left: 4rpx; /* 与上方的核心容量图标实现“强迫症级”垂直对齐 */
  box-sizing: border-box;
}

.inner-right-row {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx; /* 增加行间距，确保页面有呼吸感 */
  box-sizing: border-box;
}

/* 50% 宽度的两列行（主图、详情、水印） */
.half-row {
  width: 50%;
  padding-right: 10rpx;
}

/* 100% 宽度的整行（专门拯救长文本的转发保护） */
.full-row {
  width: 100%;
  margin-top: 2rpx;
}

.inner-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.inner-meta {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.4;
  white-space: nowrap;
}

.inner-name {
  font-weight: 500;
  color: #334155;
}

.inner-val {
  color: #64748b;
}

.bold-txt {
  font-weight: 700;
  color: #1e293b;
}
.active-item .bold-txt {
  color: #b45309;
}

/* 免费版置灰锁定态 */
.lock-right {
  opacity: 0.4;
}
.lock-right .inner-icon { filter: grayscale(100%); }
.lock-right .inner-val { text-decoration: line-through; color: #94a3b8; }

/* ==========================================================================
   6. 视频专属权益模块
   ========================================================================== */
.video-rights-card {
  margin-top: 14rpx;
  background: #f1f5f9;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}

/* 激活选中的大套餐时，下方的视频底色联动变为温润的金沙黄 */
.active-item .video-rights-card {
  background: #fffbeb;
  border-color: #fde68a;
}

.video-card-title {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #475569;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.active-item .video-card-title {
  color: #92400e;
}

.video-title-icon {
  width: 26rpx;
  height: 26rpx;
  margin-right: 8rpx;
}

.video-grid {
  display: flex;
  justify-content: space-between;
}

.video-grid-item {
  width: 48%;
  display: flex;
  flex-direction: column;
}

.video-grid-item .v-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 4rpx;
}
.active-item .video-grid-item .v-label {
  color: #b45309;
}

.video-grid-item .v-value {
  font-size: 24rpx;
  color: #1e293b;
  font-weight: 500;
}

/* 视频数字特大号突出 */
.v-num-big {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
  margin-right: 4rpx;
}
.active-item .v-num-big {
  color: #78350f;
}

/* 时长等极重要限制使用高危警告红，无限使用轻奢尊贵金 */
.v-num-big.m-warn {
  color: #e11d48 !important; 
}
.highlight-orange {
  font-size: 32rpx;
  font-weight: 800;
  color: #d97706 !important;
}

/* 顶部右上角微标签 */
.v-badge {
  position: absolute;
  top: 0;
  right: 40rpx;
  transform: translateY(-50%);
  background: #ef4444;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 8rpx rgba(239, 68, 68, 0.2);
}

.v-badge.gold {
  background: #d97706;
  box-shadow: 0 4rpx 8rpx rgba(217, 119, 6, 0.2);
}

.v-badge.current {
  background: #475569;
  box-shadow: none;
}

/* ==========================================================================
   7. 底部温馨提示区域
   ========================================================================== */
.tips-container {
  background: #f1f5f9; 
  padding: 32rpx 28rpx;
  border-radius: 16rpx;
  margin: 10rpx 30rpx 0rpx 30rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-dot {
  font-size: 28rpx;
  color: #8a9aa9;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 40rpx;
}

.tips-content {
  flex: 1;
  font-size: 24rpx;
  color: #5a6b7c; 
  line-height: 40rpx;
  text-align: justify;
}

.u-bold { font-weight: bold; color: #1e293b; }
.u-warn { color: #fa5151; font-weight: 600; }
.u-highlight { color: #07c160; font-weight: 600; }
.u-link { color: #2563eb; font-weight: 600; text-decoration: underline; margin-left: 4rpx; }

/* ==========================================================================
   8. 吸底固定的支付操作按钮栏
   ========================================================================== */
.bottom-bar-placeholder {
  height: 160rpx;
}

.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom)) 40rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.05);
  z-index: 99;
}

.bottom-action-bar .action-btn {
  width: 100% !important;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(90deg, #1e293b 0%, #475569 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  padding: 0;
  box-shadow: 0 8rpx 20rpx rgba(30, 41, 59, 0.2);
}

.bottom-action-bar .action-btn:active {
  opacity: 0.9;
}

/* ==========================================================================
   9. 半屏微信支付收银台弹窗样式
   ========================================================================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}
.mask-show { visibility: visible; opacity: 1; }

.payment-modal {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #ffffff;
  z-index: 1001;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  transform: translateY(100%);
  transition: all 0.3s cubic-bezier(0.25, 0.5, 0.5, 0.9);
  padding-bottom: env(safe-area-inset-bottom);
}
.modal-show { transform: translateY(0); }

.modal-header { padding: 40rpx; text-align: center; position: relative; }
.modal-title { font-size: 34rpx; font-weight: 700; color: #1e293b; }
.modal-close { position: absolute; right: 40rpx; top: 40rpx; font-size: 40rpx; color: #94a3b8; padding: 10rpx; }
.modal-body { padding: 0 50rpx 40rpx 50rpx; }

.pay-price-box { text-align: center; margin-bottom: 50rpx; color: #1e293b; }
.pay-price-box .p-unit { font-size: 40rpx; font-weight: 700; }
.pay-price-box .p-num { font-size: 80rpx; font-weight: 700; letter-spacing: -2rpx; }
.pay-price-box .p-time { font-size: 28rpx; color: #64748b; margin-left: 10rpx; }

.pay-order-info { background: #f8fafc; border-radius: 20rpx; padding: 30rpx; margin-bottom: 50rpx; }
.info-item { display: flex; justify-content: space-between; margin-bottom: 20rpx; font-size: 26rpx; }
.info-item .label { color: #64748b; }
.info-item .val { color: #1e293b; font-weight: 600; }

.upgrade-info-card { margin-top: 20rpx; padding: 20rpx; background: #fffbeb; border: 1rpx solid #fef3c7; border-radius: 12rpx; }
.u-tip-head { font-size: 24rpx; color: #b45309; font-weight: 700; margin-bottom: 8rpx; }
.u-tip-content { font-size: 22rpx; color: #d97706; line-height: 1.5; }

.pay-confirm-btn {
  width: 100% !important;
  max-width: 100% !important;
  height: 100rpx;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  background: #1e293b;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  margin: 40rpx 0 30rpx 0 !important;
  padding: 0 !important;
  box-sizing: border-box !important;
}
.pay-confirm-btn:active { opacity: 0.9; }
.pay-help-link { text-align: center; font-size: 26rpx; color: #2563eb; font-weight: 500; text-decoration: underline; padding: 10rpx 0; display: block; width: 100%; }